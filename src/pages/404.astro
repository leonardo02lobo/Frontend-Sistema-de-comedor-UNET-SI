---
import Layout from "../layout/Layout.astro";
---

<Layout title="404 | Página no encontrada" disableAuthGuard>
	<main class="not-found-page">
		<div class="not-found-glow not-found-glow--left" aria-hidden="true"></div>
		<div class="not-found-glow not-found-glow--right" aria-hidden="true"></div>

		<section class="not-found-card">
			<p class="not-found-kicker">Error 404</p>
			<h1>Página no encontrada</h1>
			<p>
				Esta ruta no existe o fue movida. Te llevamos de vuelta al flujo principal del
				comedor.
			</p>

			<div class="not-found-actions">
				<a href="/" class="not-found-btn not-found-btn--primary">Ir al menú</a>
				<a href="/login" class="not-found-btn not-found-btn--ghost">Iniciar sesión</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.not-found-page {
		min-height: 100dvh;
		display: grid;
		place-items: center;
		position: relative;
		overflow: hidden;
		padding: 1.5rem;
		background:
			radial-gradient(1200px 600px at 50% 110%, rgba(255, 138, 0, 0.22), transparent 65%),
			linear-gradient(180deg, #fbfbfb 0%, #f3f3f3 100%);
	}

	.not-found-glow {
		position: absolute;
		width: 24rem;
		height: 24rem;
		border-radius: 999px;
		filter: blur(60px);
		opacity: 0.3;
		pointer-events: none;
	}

	.not-found-glow--left {
		background: rgba(255, 138, 0, 0.7);
		top: -8rem;
		left: -8rem;
	}

	.not-found-glow--right {
		background: rgba(59, 153, 255, 0.4);
		bottom: -10rem;
		right: -8rem;
	}

	.not-found-card {
		width: min(100%, 42rem);
		border: 1px solid var(--color-neutral-200);
		border-radius: 1.25rem;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(6px);
		box-shadow: 0 20px 45px rgba(0, 0, 0, 0.12);
		padding: 2rem 1.5rem;
		text-align: center;
		animation: not-found-reveal 240ms ease-out;
	}

	.not-found-kicker {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		background: rgba(255, 138, 0, 0.14);
		color: var(--color-activo);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0.9rem 0 0.65rem;
		color: var(--color-neutral-900);
		font-size: clamp(1.9rem, 3.6vw, 2.8rem);
		line-height: 1.1;
	}

	p {
		margin: 0 auto;
		max-width: 34ch;
		color: var(--color-neutral-500);
		font-size: clamp(0.95rem, 2vw, 1.05rem);
		line-height: 1.55;
	}

	.not-found-actions {
		margin-top: 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.not-found-btn {
		min-width: 10.5rem;
		padding: 0.8rem 1rem;
		border-radius: 0.75rem;
		font-weight: 700;
		text-decoration: none;
		transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease, color 160ms ease;
	}

	.not-found-btn:hover {
		transform: translateY(-1px);
	}

	.not-found-btn--primary {
		background: var(--color-primario);
		color: #fff;
		box-shadow: 0 10px 22px rgba(255, 138, 0, 0.32);
	}

	.not-found-btn--primary:hover {
		background: var(--color-hover);
	}

	.not-found-btn--ghost {
		background: #fff;
		color: var(--color-neutral-900);
		border: 1px solid var(--color-neutral-200);
	}

	.not-found-btn--ghost:hover {
		background: #f7f7f7;
	}

	@keyframes not-found-reveal {
		from {
			opacity: 0;
			transform: translateY(8px) scale(0.99);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@media (max-width: 640px) {
		.not-found-card {
			padding: 1.6rem 1.1rem;
		}

		.not-found-btn {
			width: 100%;
		}
	}
</style>
