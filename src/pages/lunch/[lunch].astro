---
import Layout from "../../layout/Layout.astro";
import LunchMealView from "../../feature/lunch/components/LunchMealView.astro";
import PageShell from "../../components/PageShell.astro";
import { fetchLunchMeal, getAllLunches } from "../../feature/lunch/data.js";

export async function getStaticPaths() {
  const lunches = await getAllLunches();

  return lunches
    .filter((lunch) => lunch?.id !== null && lunch?.id !== undefined && String(lunch.id) !== "")
    .map((lunch) => ({
      params: {
        lunch: String(lunch.id),
      },
    }));
}

const lunchId = Astro.params.lunch ?? "";
const lunchItem = await fetchLunchMeal(lunchId);
---

<Layout>
  <PageShell icon={lunchItem.imageUrl}>
    <LunchMealView lunchId={lunchId} />
  </PageShell>
</Layout>
