---
import Layout from "../../layout/Layout.astro";
import LunchMealView from "../../feature/lunch/components/LunchMealView.astro";
import PageShell from "../../components/PageShell.astro";
import { getAllLunches } from "../../feature/lunch/type";

type LunchItem = {
  id?: number | string | null;
};

export async function getStaticPaths() {
  const lunches = await getAllLunches();

  return (lunches as LunchItem[])
    .filter((lunch) => lunch?.id !== null && lunch?.id !== undefined && String(lunch.id) !== "")
    .map((lunch) => ({
      params: {
        lunch: String(lunch.id),
      },
    }));
}

const menuId = Astro.params.lunch ?? "";
---

<Layout>
  <PageShell>
    <LunchMealView mealId={menuId} />
  </PageShell>
</Layout>
