---
import { URL_BASE_IMAGES } from "../models/type";
import Back from "./icons/Back.astro";

type Props = {
    icon?: string;
};

const { icon = "" } = Astro.props as Props;
---

<header
    class="relative lg:static w-full lg:w-auto lg:max-w-sm lg:shrink-0 lg:flex lg:flex-col lg:justify-center lg:items-center lg:px-3.5 lg:gap-6"
>
    <Back />
    <div class="flex justify-center items-center w-full h-full lg:mx-20 py-4">
        {icon && (
            <img
                src={URL_BASE_IMAGES + icon}
                alt="Icono de la página"
                class="w-60 h-60 lg:w-80 lg:h-80 rounded-full object-cover"
            />
        )}
    </div>
</header>
