---
import ArrowLeft from "./icons/ArrowLeft.astro";

export interface Props {
    class?: string;
    ariaLabel?: string;
    fallbackHref?: string;
    returnKeys?: string[];
    colorClass?: string;
}

const {
    class: className = "",
    ariaLabel = "Volver",
    fallbackHref = "/",
    returnKeys = ["history:return", "dashboard:return", "menu:return"],
    colorClass = "text-neutral-900",
} = Astro.props;
---

<button
    type="button"
    aria-label={ariaLabel}
    data-back-button
    data-fallback-href={fallbackHref}
    data-return-keys={JSON.stringify(returnKeys)}
    class:list={[
        "back-btn inline-flex items-center justify-center rounded-lg p-2 transition-colors hover:bg-neutral-200",
        colorClass,
        className,
    ]}
>
    <ArrowLeft />
</button>

<script is:inline>
    function parseReturnKeys(rawValue) {
        if (!rawValue) return [];

        try {
            const parsed = JSON.parse(rawValue);
            if (!Array.isArray(parsed)) return [];
            return parsed.map((item) => String(item || "")).filter(Boolean);
        } catch {
            return [];
        }
    }

    function normalizePath(pathname) {
        const safePath = String(pathname || "");
        if (safePath.length > 1 && safePath.endsWith("/")) {
            return safePath.slice(0, -1);
        }
        return safePath || "/";
    }

    function goBackWithMemory(button) {
        const fallbackHref = String(button.dataset.fallbackHref || "/");
        const returnKeys = parseReturnKeys(button.dataset.returnKeys);
        const currentPath = normalizePath(window.location.pathname);

        for (const key of returnKeys) {
            const rawValue = sessionStorage.getItem(key);
            if (!rawValue) continue;

            try {
                const parsed = JSON.parse(rawValue);
                const targetPath = String(parsed?.path || "");
                if (!targetPath) continue;
                if (normalizePath(targetPath) === currentPath) continue;
                window.location.href = targetPath;
                return;
            } catch {
                // Ignoramos valores invalidos y continuamos con la siguiente key.
            }
        }

        if (window.history.length > 1) {
            window.history.back();
            return;
        }

        window.location.href = fallbackHref;
    }

    function bindBackButtons() {
        document.querySelectorAll("[data-back-button]").forEach((element) => {
            if (!(element instanceof HTMLButtonElement)) return;
            if (element.dataset.backBound === "true") return;

            element.dataset.backBound = "true";
            element.addEventListener("click", () => goBackWithMemory(element));
        });
    }

    document.addEventListener("astro:page-load", bindBackButtons);
    bindBackButtons();
</script>