---
import ArrowLeft from "./icons/ArrowLeft.astro";

export interface Props {
    class?: string;
    ariaLabel?: string;
    fallbackHref?: string;
    returnKeys?: string[];
    colorClass?: string;
}

const {
    class: className = "",
    ariaLabel = "Volver",
    fallbackHref = "/",
    returnKeys = ["history:return", "dashboard:return", "menu:return"],
    colorClass = "text-neutral-900",
} = Astro.props;
---

<button
    type="button"
    aria-label={ariaLabel}
    data-back-button
    data-fallback-href={fallbackHref}
    data-return-keys={JSON.stringify(returnKeys)}
    class:list={[
        "back-btn inline-flex items-center justify-center rounded-lg p-2 transition-colors hover:bg-neutral-200",
        colorClass,
        className,
    ]}
>
    <ArrowLeft />
</button>

<script is:inline data-astro-rerun>
    (function () {
        var btn = document.querySelector("[data-back-button][data-fallback-href]");
        if (!btn) return;
        var fallback = btn.getAttribute("data-fallback-href") || "/";
        btn.addEventListener("click", function () {
            if (window.history.length > 1) {
                window.history.back();
            } else {
                window.location.href = fallback;
            }
        });
    })();
</script>