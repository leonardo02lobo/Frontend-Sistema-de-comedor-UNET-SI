---
import ArrowLeft from "../../../components/icons/ArrowLeft.astro";
import "../style.css";
---

<section class="dashboard-view flex min-h-0 flex-1 flex-col bg-white px-5 py-5 lg:px-8 lg:py-6">
  <div class="flex flex-col gap-4 min-h-0 flex-1">
    <header class="flex flex-col gap-2">
      <div class="-ml-1 w-fit">
        <a href="/dashboard">
          <ArrowLeft />
        </a>
      </div>

      <h1 class="flex justify-center text-3xl md:text-4xl lg:text-5xl font-bold" style="color: var(--color-neutral-900)">
        Almuerzos Disponibles
      </h1>
    </header>

    <div class="sticky top-0 z-20 bg-white pt-2 pb-2">
      <label class="relative block">
        <input
          id="meals-search"
          type="search"
          placeholder="Buscar comida, bebida..."
          class="w-full rounded-lg border px-3 py-2 text-sm md:text-base"
          style="border-color: var(--color-neutral-200);"
        />
        <span class="absolute right-3 top-1/2 -translate-y-1/2">⌕</span>
      </label>

      <div class="flex flex-wrap justify-center gap-2 mt-2">
        <button class="filter-btn active" data-filter="all">Todo</button>
        <button class="filter-btn" data-filter="active">Con stock</button>
        <button class="filter-btn" data-filter="empty">Agotado</button>
      </div>
    </div>

    <div id="meals-list" class="flex flex-col gap-3 pt-2 overflow-y-auto overflow-x-visible pb-4">
      <p class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm font-medium text-neutral-500 sm:text-base">
        Cargando platillos...
      </p>
    </div>
  </div>

  <div id="delete-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/30" hidden>
    <div class="rounded-2xl bg-white p-6 flex flex-col items-center gap-4 w-full max-w-xs">
      <div class="flex items-center justify-center w-14 h-14 rounded-full" style="background: color-mix(in srgb, var(--color-error) 12%, white);">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="color: var(--color-error)"
        >
          <path d="M12 9v4" />
          <path d="M12 16h.01" />
          <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z" />
        </svg>
      </div>

      <p class="text-center font-semibold">Seguro de eliminar el plato?</p>

      <button id="confirm-delete" class="w-full rounded-xl py-2 text-white" style="background: var(--color-error)">
        Si, eliminar
      </button>

      <button id="cancel-delete" class="w-full rounded-xl py-2 border" style="border-color: var(--color-neutral-200)">
        Cancelar
      </button>
    </div>
  </div>
</section>

<script>
  const API_BASE     = "http://localhost:3001";
  const FALLBACK_IMG = "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=80&q=80";

  function resolveImageUrl(src) {
    if (!src) return FALLBACK_IMG;
    if (src.startsWith("data:") || src.startsWith("http")) return src;
    if (src.startsWith("/")) return API_BASE + src;
    return API_BASE + "/images/" + src;
  }

  function initMealsList() {
    const list        = document.getElementById("meals-list");
    const searchInput = document.getElementById("meals-search");
    const modal       = document.getElementById("delete-modal");
    const confirmBtn  = document.getElementById("confirm-delete");
    const cancelBtn   = document.getElementById("cancel-delete");

    if (!list) return; // no estamos en esta página

    let meals         = [];
    let activeFilter  = "all";
    let pendingDelete = null;

    function normalize(t) { return String(t || "").toLowerCase().trim(); }

  // ── Render ────────────────────────────────────────────────────────
  function applyFilters() {
    var q        = normalize(searchInput ? searchInput.value : "");
    var filtered = meals.filter(function (m) {
      if (!normalize(m.name).includes(q)) return false;
      if (activeFilter === "active") return m.remaining > 0;
      if (activeFilter === "empty")  return m.remaining === 0;
      return true;
    });

    if (filtered.length === 0) {
      list.innerHTML = '<p class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm font-medium text-brand-muted sm:text-base">No hay resultados para este filtro.</p>';
      return;
    }

    list.innerHTML = filtered.map(function (meal) {
      return '<div class="flex items-center justify-between gap-3 rounded-xl border px-3 py-3" style="border-color:var(--color-brand-line);background:var(--color-neutral-0);">' +
        '<div class="flex items-center gap-3 min-w-0">' +
          '<img src="' + meal.image + '" alt="' + meal.name + '" class="h-12 w-12 rounded-full object-cover shrink-0" onerror="this.src=\'' + FALLBACK_IMG + '\'" />' +
          '<div class="flex flex-col min-w-0">' +
            '<span class="font-semibold text-base truncate" style="color:var(--color-neutral-900)">' + meal.name + '</span>' +
            '<span class="text-xs" style="color:var(--color-primario)">Precio: $' + meal.price.toFixed(2) + ' · Restantes: ' + meal.remaining + '</span>' +
          '</div>' +
        '</div>' +
        '<div class="flex items-center gap-1.5 shrink-0">' +
          '<a href="/lunch/' + meal.lunchId + '" class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors" style="color:var(--color-neutral-500)"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg></a>' +
          '<a href="/edit-meal?id=' + meal.lunchId + '" class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors" style="color:var(--color-neutral-500)"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></a>' +
          '<button type="button" data-delete-id="' + meal.lunchId + '" class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors" style="color:var(--color-error)"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"/><path d="M19 6v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg></button>' +
        '</div>' +
      '</div>';
    }).join("");
  }

  // ── Fetch ─────────────────────────────────────────────────────────
  async function loadMeals() {
    try {
      var res     = await fetch(API_BASE + "/api/lunches", { method: "GET", credentials: "include" });
      if (!res.ok) throw new Error("No se pudo cargar la lista de platillos.");
      var payload = await res.json();
      var lunches = Array.isArray(payload && payload.data) ? payload.data : [];
      meals = lunches
        .map(function (l) {
          return {
            lunchId:   Number(l.id || 0),
            name:      l.nombrePlatoPrincipal || ("Platillo " + l.id),
            image:     resolveImageUrl(l.image),
            remaining: Number(l.stockActual || 0),
            price:     Number(l.precio || 0),
          };
        })
        .filter(function (m) { return m.lunchId > 0; });
      applyFilters();
    } catch (err) {
      list.innerHTML = '<p class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm font-medium text-brand-muted sm:text-base">' + (err.message || "Error al cargar.") + '</p>';
    }
  }

  // ── Delete ────────────────────────────────────────────────────────
  async function confirmDelete() {
    if (!pendingDelete) return;
    try {
      var res     = await fetch(API_BASE + "/api/lunches/" + pendingDelete, { method: "DELETE", credentials: "include" });
      var payload = await res.json();
      if (!res.ok || !payload.success) throw new Error(payload.error || "No se pudo eliminar.");
      pendingDelete = null;
      modal && modal.setAttribute("hidden", "");
      await loadMeals();
    } catch (err) {
      alert(err.message || "No se pudo eliminar.");
    }
  }

  // ── Filtros y búsqueda ────────────────────────────────────────────
  if (searchInput) searchInput.addEventListener("input", applyFilters);

  document.querySelectorAll(".filter-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      activeFilter = btn.dataset.filter || "all";
      document.querySelectorAll(".filter-btn").forEach(function (b) { b.classList.remove("active"); });
      btn.classList.add("active");
      applyFilters();
    });
  });

  list.addEventListener("click", function (e) {
    var del = e.target.closest ? e.target.closest("[data-delete-id]") : null;
    if (!del) return;
    pendingDelete = Number(del.dataset.deleteId);
    modal && modal.removeAttribute("hidden");
  });

  if (confirmBtn) confirmBtn.addEventListener("click", confirmDelete);
  if (cancelBtn)  cancelBtn.addEventListener("click", function () {
    pendingDelete = null;
    modal && modal.setAttribute("hidden", "");
  });
  if (modal) modal.addEventListener("click", function (e) {
    if (e.target === modal) { pendingDelete = null; modal.setAttribute("hidden", ""); }
  });

  // ── Arrancar ──────────────────────────────────────────────────────
    loadMeals();
  }

  document.addEventListener("astro:page-load", initMealsList);
</script>
