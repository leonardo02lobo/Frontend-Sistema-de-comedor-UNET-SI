---
import ArrowLeft from "../../../components/icons/ArrowLeft.astro";
import "../style.css";
---

<section class="dashboard-view flex min-h-0 flex-1 flex-col bg-white px-5 py-5 lg:px-8 lg:py-6">
  <div class="flex flex-col gap-4 min-h-0 flex-1">
    <header class="flex flex-col gap-2">
      <div class="-ml-1 w-fit">
        <a href="/dashboard">
          <ArrowLeft />
        </a>
      </div>

      <h1 class="flex justify-center text-3xl md:text-4xl lg:text-5xl font-bold" style="color: var(--color-neutral-900)">
        Almuerzos Disponibles
      </h1>
    </header>

    <div class="sticky top-0 z-20 bg-white pt-2 pb-2">
      <label class="relative block">
        <input
          id="meals-search"
          type="search"
          placeholder="Buscar comida, bebida..."
          class="w-full rounded-lg border px-3 py-2 text-sm md:text-base"
          style="border-color: var(--color-neutral-200);"
        />
        <span class="absolute right-3 top-1/2 -translate-y-1/2">⌕</span>
      </label>

      <div class="flex flex-wrap justify-center gap-2 mt-2">
        <button class="filter-btn active" data-filter="all">Todo</button>
        <button class="filter-btn" data-filter="active">Con stock</button>
        <button class="filter-btn" data-filter="empty">Agotado</button>
      </div>
    </div>

    <div id="meals-list" class="flex flex-col gap-3 pt-2 overflow-y-auto overflow-x-visible pb-4">
      <p class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm font-medium text-neutral-500 sm:text-base">
        Cargando platillos...
      </p>
    </div>
  </div>

  <div id="delete-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/30" hidden>
    <div class="rounded-2xl bg-white p-6 flex flex-col items-center gap-4 w-full max-w-xs">
      <div class="flex items-center justify-center w-14 h-14 rounded-full" style="background: color-mix(in srgb, var(--color-error) 12%, white);">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="color: var(--color-error)"
        >
          <path d="M12 9v4" />
          <path d="M12 16h.01" />
          <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z" />
        </svg>
      </div>

      <p class="text-center font-semibold">Seguro de eliminar el plato?</p>

      <button id="confirm-delete" class="w-full rounded-xl py-2 text-white" style="background: var(--color-error)">
        Si, eliminar
      </button>

      <button id="cancel-delete" class="w-full rounded-xl py-2 border" style="border-color: var(--color-neutral-200)">
        Cancelar
      </button>
    </div>
  </div>
</section>

<script lang="js">
  document.addEventListener("astro:page-load", () => {
    const FALLBACK_IMAGE = "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=80&q=80";

    let meals = [];
    let activeFilter = "all";
    let pendingDeleteId = null;

    const normalize = (text) => String(text || "").toLowerCase().trim();

    async function fetchData() {
      const response = await fetch("http://localhost:3001/api/lunches", {
        method: "GET",
        credentials: "include",
      });

      if (!response.ok) throw new Error("No se pudo cargar la lista de platillos.");

      const payload = await response.json();
      const lunches = Array.isArray(payload?.data) ? payload.data : [];

      meals = lunches
        .map((lunch) => ({
          lunchId: Number(lunch.id ?? 0),
          name: lunch.nombrePlatoPrincipal || `Platillo ${lunch.id}`,
          image: lunch.image
            ? (lunch.image.startsWith("data:") || lunch.image.startsWith("http") ? lunch.image : `http://localhost:3001/images/${lunch.image}`)
            : FALLBACK_IMAGE,
          remaining: Number(lunch.stockActual ?? 0),
          price: Number(lunch.precio ?? 0),
        }))
        .filter((item) => item.lunchId > 0);
    }

    function applyFilters() {
      const list = document.getElementById("meals-list");
      const searchInput = document.getElementById("meals-search");
      if (!list) return;

      const searchValue = normalize(searchInput?.value || "");
      const filtered = meals.filter((meal) => {
        const matchesSearch = normalize(meal.name).includes(searchValue);
        if (!matchesSearch) return false;
        if (activeFilter === "active") return meal.remaining > 0;
        if (activeFilter === "empty") return meal.remaining === 0;
        return true;
      });

      if (filtered.length === 0) {
        list.innerHTML = `
          <p class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm font-medium text-brand-muted sm:text-base">
            No hay resultados para este filtro.
          </p>
        `;
        return;
      }

      list.innerHTML = filtered
        .map((meal) => `
          <div class="flex items-center justify-between gap-3 rounded-xl border px-3 py-3" style="border-color: var(--color-brand-line); background: var(--color-neutral-0);">
            <div class="flex items-center gap-3 min-w-0">
              <img src="${meal.image}" alt="${meal.name}" class="h-12 w-12 rounded-full object-cover shrink-0"
                onerror="this.src='${FALLBACK_IMAGE}'" />
              <div class="flex flex-col min-w-0">
                <span class="font-semibold text-base truncate" style="color: var(--color-neutral-900)">${meal.name}</span>
                <span class="text-xs" style="color: var(--color-primario)">Precio: $${meal.price.toFixed(2)} · Restantes: ${meal.remaining}</span>
              </div>
            </div>
            <div class="flex items-center gap-1.5 shrink-0">
              <a href="/lunch/${meal.lunchId}" class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors" style="color: var(--color-neutral-500)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
              </a>
              <a href="/edit-meal?id=${meal.lunchId}" class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors" style="color: var(--color-neutral-500)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </a>
              <button type="button" data-delete-id="${meal.lunchId}" class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors" style="color: var(--color-error)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"/><path d="M19 6v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
              </button>
            </div>
          </div>
        `)
        .join("");
    }

    async function deleteMeal() {
      if (!pendingDeleteId) return;

      const response = await fetch(`http://localhost:3001/api/lunches/${pendingDeleteId}`, {
        method: "DELETE",
        credentials: "include",
      });

      const payload = await response.json();
      if (!response.ok || !payload?.success) {
        throw new Error(payload?.error || "No se pudo eliminar el platillo.");
      }

      pendingDeleteId = null;
      document.getElementById("delete-modal")?.setAttribute("hidden", "");
      await loadMeals();
    }

    async function loadMeals() {
      try {
        await fetchData();
        applyFilters();
      } catch (error) {
        const list = document.getElementById("meals-list");
        if (!list) return;
        const message = error instanceof Error ? error.message : "No se pudo cargar la lista.";
        list.innerHTML = `
          <p class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm font-medium text-brand-muted sm:text-base">
            ${message}
          </p>
        `;
      }
    }

    function bindEvents() {
      const searchInput = document.getElementById("meals-search");
      const filters = document.querySelectorAll(".filter-btn");
      const list = document.getElementById("meals-list");
      const modal = document.getElementById("delete-modal");
      const confirmBtn = document.getElementById("confirm-delete");
      const cancelBtn = document.getElementById("cancel-delete");

      searchInput?.addEventListener("input", applyFilters);

      filters.forEach((button) => {
        if (button.dataset.bound === "true") return;
        button.dataset.bound = "true";
        button.addEventListener("click", () => {
          activeFilter = button.dataset.filter || "all";
          filters.forEach((item) => item.classList.remove("active"));
          button.classList.add("active");
          applyFilters();
        });
      });

      if (list && list.dataset.bound !== "true") {
        list.dataset.bound = "true";
        list.addEventListener("click", (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) return;
          const deleteButton = target.closest("[data-delete-id]");
          if (!deleteButton) return;
          pendingDeleteId = Number(deleteButton.dataset.deleteId);
          modal?.removeAttribute("hidden");
        });
      }

      if (confirmBtn && confirmBtn.dataset.bound !== "true") {
        confirmBtn.dataset.bound = "true";
        confirmBtn.addEventListener("click", async () => {
          try {
            await deleteMeal();
          } catch (error) {
            alert(error instanceof Error ? error.message : "No se pudo eliminar.");
          }
        });
      }

      if (cancelBtn && cancelBtn.dataset.bound !== "true") {
        cancelBtn.dataset.bound = "true";
        cancelBtn.addEventListener("click", () => {
          pendingDeleteId = null;
          modal?.setAttribute("hidden", "");
        });
      }

      if (modal && modal.dataset.bound !== "true") {
        modal.dataset.bound = "true";
        modal.addEventListener("click", (event) => {
          if (event.target === modal) {
            pendingDeleteId = null;
            modal.setAttribute("hidden", "");
          }
        });
      }
    }

    async function initMealsList() {
      bindEvents();
      await loadMeals();
    }

    initMealsList();
  });
</script>
