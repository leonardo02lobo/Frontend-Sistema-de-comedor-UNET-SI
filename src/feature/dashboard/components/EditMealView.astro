---
import BackButton from "../../../components/BackButton.astro";
import Plus from "../../../components/icons/Plus.astro";
import "../style.css";
---

<section
  class="dashboard-view flex flex-1 flex-col bg-neutral-0 px-4 py-4 gap-4 md:px-6 md:py-6 md:gap-5 lg:px-10 lg:py-8 lg:gap-6 overflow-y-auto relative"
>
  <!-- Botón volver -->
  <BackButton
    class="absolute top-4 left-4 z-10 md:top-5 md:left-5 lg:top-6 lg:left-6"
    fallbackHref="/profile"
    ariaLabel="Volver a la vista anterior"
  />

  <!-- Header -->
  <header class="text-center pt-8 md:pt-0">
    <h1
      class="text-2xl md:text-3xl lg:text-4xl font-bold"
      style="color: var(--color-neutral-900)"
    >
      Editar
    </h1>
  </header>

  <!-- Formulario -->
  <form
    id="edit-meal-form"
    class="rounded-2xl p-4 md:p-6 flex flex-col gap-4"
    style="background: var(--color-neutral-0);"
  >
    <!-- Nombre -->
    <div class="flex flex-col gap-1">
      <label class="font-semibold">Nombre</label>
      <input
        id="name"
        type="text"
        class="rounded-xl px-4 py-2 border bg-neutral-0"
        style="border-color: var(--color-neutral-200);"
      />
    </div>

    <!-- Descripción -->
    <div class="flex flex-col gap-1">
      <label class="font-semibold">Descripción</label>
      <textarea
        id="description"
        class="rounded-xl px-4 py-2 border bg-neutral-0"
        style="border-color: var(--color-neutral-200);"
      ></textarea>
    </div>

    <!-- Ingredientes -->
    <div class="flex flex-col gap-1">
      <label class="font-semibold">Ingredientes</label>
      <input
        id="ingredients"
        type="text"
        class="rounded-xl px-4 py-2 border bg-neutral-0"
        style="border-color: var(--color-neutral-200);"
      />
    </div>

    <!-- Cantidad -->
    <div class="flex flex-col gap-1">
      <label class="font-semibold">Cantidad Disponible</label>
      <div
        class="flex items-center gap-2 rounded-xl border px-4 py-2 bg-neutral-0"
        style="border-color: var(--color-neutral-200);"
      >
        <button type="button" id="minus" class="px-2 text-lg font-bold select-none">-</button>
        <input
          id="quantity"
          type="number"
          min="1"
          class="flex-1 text-center bg-transparent outline-none"
          value="1"
        />
        <button type="button" id="plus" class="px-2 text-lg font-bold select-none">+</button>
      </div>
    </div>

    <!-- Precio -->
    <div class="flex flex-col gap-1">
      <label class="font-semibold">Precio</label>
      <input
        id="price"
        type="number"
        min="0"
        step="0.01"
        class="rounded-xl px-4 py-2 border bg-neutral-0"
        style="border-color: var(--color-brand-line);"
      />
    </div>

    <!-- Imagen -->
    <div class="flex flex-col gap-2">
      <label class="font-semibold">Imagen</label>
      <input type="file" id="image" accept="image/*" hidden />
      <button
        type="button"
        id="upload-btn"
        class="rounded-xl border px-4 py-3 bg-neutral-0 text-left flex items-center gap-2"
        style="border-color: var(--color-neutral-200);"
      >
        <Plus />
        Adjuntar Imagen
      </button>
      <img id="preview" class="hidden rounded-xl max-h-40 object-cover" />
    </div>

    <!-- Botón editar -->
    <button
      type="submit"
      class="w-full rounded-xl py-3 font-semibold text-white"
      style="background: var(--color-primario);"
    >
      Guardar Cambios
    </button>
  </form>
</section>

<script lang="js">
  document.addEventListener("astro:page-load", () => {
    let currentImageUrl = "";
    let lunchId = null;

    const nameInput = document.getElementById("name");
    const descriptionInput = document.getElementById("description");
    const ingredientsInput = document.getElementById("ingredients");
    const quantityEl = document.getElementById("quantity");
    const priceInput = document.getElementById("price");
    const imageInput = document.getElementById("image");
    const preview = document.getElementById("preview");
    const uploadBtn = document.getElementById("upload-btn");
    const form = document.getElementById("edit-meal-form");

    const params = new URLSearchParams(window.location.search);
    const paramId = Number(params.get("id"));
    if (Number.isFinite(paramId) && paramId > 0) {
      lunchId = paramId;
    }

    async function loadLunch() {
      if (!lunchId) return;
      try {
        const response = await fetch(`http://localhost:3001/api/lunches/${lunchId}`, {
          credentials: "include",
        });
        const payload = await response.json();
        if (!response.ok || !payload?.success) {
          throw new Error(payload?.error || "No se pudo cargar el platillo.");
        }

        const lunch = payload.data || {};
        nameInput.value = lunch.nombrePlatoPrincipal || "";
        descriptionInput.value = lunch.descripcion || "";
        ingredientsInput.value = Array.isArray(lunch.ingredientes)
          ? lunch.ingredientes.join(", ")
          : String(lunch.ingredientes || "");
        quantityEl.value = Number(lunch.stockActual || 1);
        priceInput.value = String(lunch.precio ?? "");
        currentImageUrl = lunch.image || "";
        if (currentImageUrl) {
          preview.src = currentImageUrl.startsWith("data:") || currentImageUrl.startsWith("http")
            ? currentImageUrl
            : `http://localhost:3001/images/${currentImageUrl}`;
          preview.classList.remove("hidden");
        }
      } catch (error) {
        alert(error instanceof Error ? error.message : "No se pudo cargar el platillo.");
      }
    }

    document.getElementById("plus")?.addEventListener("click", () => {
      quantityEl.value = Math.max(1, Number(quantityEl.value || 1) + 1);
    });

    document.getElementById("minus")?.addEventListener("click", () => {
      quantityEl.value = Math.max(1, Number(quantityEl.value || 1) - 1);
    });

    uploadBtn.addEventListener("click", () => {
      imageInput.click();
    });

    imageInput.addEventListener("change", () => {
      const file = imageInput.files[0];
      if (!file) return;
      preview.src = URL.createObjectURL(file);
      preview.classList.remove("hidden");
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!lunchId) {
        alert("No se encontro el platillo a editar.");
        return;
      }

      const name = nameInput.value.trim();
      const description = descriptionInput.value.trim();
      const ingredients = ingredientsInput.value.trim();
      const priceValue = priceInput.value.trim();
      const price = Number(priceValue);

      if (!name || !description || !ingredients || !priceValue || Number.isNaN(price)) {
        alert("Completa todos los campos");
        return;
      }

      let imageUrl = currentImageUrl;
      const file = imageInput.files[0];

      const toBase64 = (f) => new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = reject;
        reader.readAsDataURL(f);
      });

      const submitBtn = form.querySelector("button[type='submit']");
      submitBtn.disabled = true;
      submitBtn.textContent = "Guardando...";

      try {
        const body = {
          nombrePlatoPrincipal: name,
          descripcion: description,
          ingredientes: ingredients.split(",").map(s => s.trim()).filter(Boolean),
          stockActual: Math.max(1, Number(quantityEl.value || 1)),
          precio: price,
        };

        if (file) {
          body.image = await toBase64(file);
        }

        const response = await fetch(`http://localhost:3001/api/lunches/${lunchId}`, {
          method: "PATCH",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });

        const payload = await response.json();
        if (!response.ok || !payload?.success) {
          throw new Error(payload?.error || payload?.message || "No se pudo actualizar el platillo.");
        }

        window.location.href = "/dashboard";
      } catch (error) {
        alert(error instanceof Error ? error.message : "No se pudo actualizar el platillo.");
        submitBtn.disabled = false;
        submitBtn.textContent = "Guardar Cambios";
      }
    });

    loadLunch();
  });
</script>