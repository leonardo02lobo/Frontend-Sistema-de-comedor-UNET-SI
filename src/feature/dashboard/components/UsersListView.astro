---
import ArrowLeft from "../../../components/icons/ArrowLeft.astro";
import Plus from "../../../components/icons/Plus.astro";
import "../style.css";
---

<section class="dashboard-view flex min-h-0 flex-1 flex-col bg-neutral-0 px-4 py-4 gap-4 md:px-6 md:py-6 md:gap-5 lg:px-10 lg:py-8 lg:gap-6 overflow-y-auto">

  <div class="flex flex-col gap-4 min-h-0 flex-1">
    <header class="flex flex-col gap-2">
      <div class="-ml-1 w-fit">
        <a href="/dashboard"><ArrowLeft /></a>
      </div>
      <h1 class="flex justify-center text-3xl md:text-4xl lg:text-5xl font-bold"
          style="color: var(--color-neutral-900)">
        Usuarios
      </h1>
    </header>

    <a href="/add-user"
       class="flex items-center justify-center gap-2 w-full rounded-xl px-4 py-2.5 md:py-3 text-sm md:text-base font-semibold text-white transition-colors shrink-0"
       style="background: var(--color-primario);">
      <Plus />
      Agregar Usuario
    </a>

    <div class="sticky top-0 z-20 pt-1 pb-1" style="background: var(--color-neutral-0);">
      <input
        id="users-search"
        type="search"
        placeholder="Buscar por nombre, cédula o correo..."
        class="w-full rounded-lg border px-3 py-2 text-sm md:text-base"
        style="border-color: var(--color-neutral-200);"
      />
    </div>

    <div id="users-list" class="flex flex-col gap-3 pt-1 overflow-y-auto pb-4">
      <p class="rounded-xl border border-dashed px-4 py-6 text-center text-sm font-medium"
         style="border-color: var(--color-neutral-200); color: var(--color-neutral-500);">
        Cargando usuarios...
      </p>
    </div>
  </div>

  <!-- Modal eliminar -->
  <div id="delete-user-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/30" hidden>
    <div class="rounded-2xl p-6 flex flex-col items-center gap-4 w-full max-w-xs shadow-lg"
         style="background: var(--color-neutral-0);">
      <div class="flex items-center justify-center w-14 h-14 rounded-full"
           style="background: color-mix(in srgb, var(--color-error) 12%, white);">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round"
             style="color: var(--color-error)">
          <path d="M12 9v4" /><path d="M12 16h.01" />
          <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z" />
        </svg>
      </div>
      <p class="text-center font-semibold" style="color: var(--color-neutral-900)">
        ¿Seguro de eliminar este usuario?
      </p>
      <button id="confirm-delete-user" class="w-full rounded-xl py-2.5 text-sm font-semibold text-white"
              style="background: var(--color-error);">
        Sí, eliminar
      </button>
      <button id="cancel-delete-user" class="w-full rounded-xl border py-2.5 text-sm font-semibold"
              style="border-color: var(--color-neutral-200); color: var(--color-neutral-900);">
        Cancelar
      </button>
    </div>
  </div>
</section>

<script lang="js">
  const API_BASE   = "http://localhost:3001";
  const DEFAULT_AV = "/default-avatar.svg";

  function resolveAvatar(imageURL) {
    if (!imageURL || imageURL === "/") return DEFAULT_AV;
    if (imageURL.startsWith("data:") || imageURL.startsWith("http")) return imageURL;
    return API_BASE + (imageURL.startsWith("/") ? imageURL : "/" + imageURL);
  }

  function initUsersList() {
    const list        = document.getElementById("users-list");
    const searchInput = document.getElementById("users-search");
    const modal       = document.getElementById("delete-user-modal");
    const confirmBtn  = document.getElementById("confirm-delete-user");
    const cancelBtn   = document.getElementById("cancel-delete-user");

    if (!list) return;

    let users         = [];
    let pendingDelete = null;

    function normalize(t) { return String(t || "").toLowerCase().trim(); }

    function applySearch() {
      const q = normalize(searchInput ? searchInput.value : "");
      const filtered = users.filter(u =>
        !q ||
        normalize(u.fullName).includes(q) ||
        normalize(u.cedula).includes(q) ||
        normalize(u.email).includes(q)
      );

      if (filtered.length === 0) {
        list.innerHTML = '<p class="rounded-xl border border-dashed px-4 py-6 text-center text-sm font-medium" style="border-color:var(--color-neutral-200);color:var(--color-neutral-500);">No hay resultados.</p>';
        return;
      }

      list.innerHTML = filtered.map(u => `
        <div class="flex items-center justify-between gap-3 rounded-xl border px-3 py-3"
             style="border-color:var(--color-neutral-200);background:var(--color-neutral-0);">
          <div class="flex items-center gap-3 min-w-0">
            <img src="${resolveAvatar(u.imageURL)}" alt="${u.fullName}"
                 class="h-11 w-11 rounded-full object-cover shrink-0 border-2"
                 style="border-color:var(--color-primario);"
                 onerror="this.src='${DEFAULT_AV}'" />
            <div class="flex flex-col min-w-0">
              <span class="font-semibold text-sm md:text-base truncate"
                    style="color:var(--color-neutral-900)">${u.fullName}</span>
              <span class="text-xs" style="color:var(--color-neutral-500)">
                ${u.cedula} &nbsp;·&nbsp; ${u.email}
              </span>
              ${u.carrera ? `<span class="text-xs" style="color:var(--color-primario)">${u.carrera}</span>` : ""}
            </div>
          </div>
          <button type="button" data-delete-id="${u.id}"
                  class="p-1.5 rounded-lg hover:bg-neutral-200 transition-colors shrink-0"
                  style="color:var(--color-error);"
                  aria-label="Eliminar ${u.fullName}">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h18"/><path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"/>
              <path d="M19 6v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6"/>
              <path d="M10 11v6"/><path d="M14 11v6"/>
            </svg>
          </button>
        </div>
      `).join("");
    }

    async function loadUsers() {
      try {
        const res = await fetch(API_BASE + "/api/admins", { method: "GET", credentials: "include" });
        if (!res.ok) throw new Error("No se pudo cargar la lista de usuarios.");
        const payload = await res.json();
        const all = Array.isArray(payload?.data) ? payload.data : [];
        users = all.filter(a => a.role === "USER");
        applySearch();
      } catch (err) {
        list.innerHTML = `<p class="rounded-xl border border-dashed px-4 py-6 text-center text-sm font-medium" style="border-color:var(--color-neutral-200);color:var(--color-neutral-500);">${err.message || "Error al cargar."}</p>`;
      }
    }

    async function confirmDelete() {
      if (!pendingDelete) return;
      try {
        const res = await fetch(API_BASE + "/api/admins/" + pendingDelete, { method: "DELETE", credentials: "include" });
        const payload = await res.json();
        if (!res.ok || !payload?.success) throw new Error(payload?.error || "No se pudo eliminar.");
        pendingDelete = null;
        modal?.setAttribute("hidden", "");
        await loadUsers();
      } catch (err) {
        alert(err.message || "No se pudo eliminar.");
      }
    }

    if (searchInput) searchInput.addEventListener("input", applySearch);

    list.addEventListener("click", e => {
      const btn = e.target.closest("[data-delete-id]");
      if (!btn) return;
      pendingDelete = Number(btn.dataset.deleteId);
      modal?.removeAttribute("hidden");
    });

    confirmBtn?.addEventListener("click", confirmDelete);
    cancelBtn?.addEventListener("click", () => {
      pendingDelete = null;
      modal?.setAttribute("hidden", "");
    });
    modal?.addEventListener("click", e => {
      if (e.target === modal) { pendingDelete = null; modal.setAttribute("hidden", ""); }
    });

    loadUsers();
  }

  document.addEventListener("astro:page-load", initUsersList);
</script>
