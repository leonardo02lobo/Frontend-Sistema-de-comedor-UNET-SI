---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
	title?: string;
}
const { title = "Sistema de gestion de comedor universitario UNET" } =
	Astro.props as Props;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<script lang="js">
			document.addEventListener("astro:page-load", () => {
				function normalizePath(pathname) {
					const safePath = String(pathname || "");
					if (safePath.length > 1 && safePath.endsWith("/")) {
						return safePath.slice(0, -1);
					}
					return safePath || "/";
				}

				function tryRestoreHistoryPosition() {
					const rawRestore =
						sessionStorage.getItem("history:restore");
					if (!rawRestore) return;

					let restore = null;
					try {
						restore = JSON.parse(rawRestore);
					} catch {
						sessionStorage.removeItem("history:restore");
						return;
					}

					const targetPath = String(restore?.path || "");
					if (!targetPath) {
						sessionStorage.removeItem("history:restore");
						return;
					}

					const targetUrl = new URL(
						targetPath,
						window.location.origin,
					);
					if (
						normalizePath(targetUrl.pathname) !==
						normalizePath(window.location.pathname)
					) {
						return;
					}

					const applyRestore = () => {
						window.scrollTo(0, Number(restore?.scrollY) || 0);

						const selector = String(
							restore?.containerSelector || "",
						);
						if (selector) {
							const container = document.querySelector(selector);
							if (container instanceof HTMLElement) {
								container.scrollTop =
									Number(restore?.containerScrollTop) || 0;
							}
						}

						sessionStorage.removeItem("history:restore");
					};
					requestAnimationFrame(() => {
						requestAnimationFrame(applyRestore);
					});
				}

				tryRestoreHistoryPosition();
			});
		</script>
		<script>
			const PUBLIC_PATHS = ["/home", "/login"];

			function isPublicPath(pathname: string) {
				const p = pathname.length > 1 && pathname.endsWith("/")
					? pathname.slice(0, -1)
					: pathname;
				return PUBLIC_PATHS.includes(p);
			}

			async function guardAuth() {
				if (isPublicPath(window.location.pathname)) return;

				try {
					const response = await fetch(
						"http://localhost:3001/api/auth/validate-cookie",
						{ method: "GET", credentials: "include" },
					);

					if (response.status === 401) {
						window.location.replace("/home");
					}
				} catch {
					// Error de red: no redirigir
				}
			}

			guardAuth();
			document.addEventListener("astro:page-load", guardAuth);
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
